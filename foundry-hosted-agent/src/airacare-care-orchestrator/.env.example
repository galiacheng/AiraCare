# Foundry project endpoint (https://<project>.services.ai.azure.com/api/projects/<name>).
# Populated automatically by `azd provision`; set manually only for standalone local runs.
FOUNDRY_PROJECT_ENDPOINT="..."

# The model deployment name created by provisioning (default: gpt-5.4-mini).
AZURE_AI_MODEL_DEPLOYMENT_NAME="gpt-5.4-mini"

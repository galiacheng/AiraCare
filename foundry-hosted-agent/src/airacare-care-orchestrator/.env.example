# Foundry project endpoint (https://<project>.services.ai.azure.com/api/projects/<name>).
# Populated automatically by `azd provision`; set manually only for standalone local runs.
FOUNDRY_PROJECT_ENDPOINT="..."

# The model deployment name created by provisioning (default: gpt-5.4).
AZURE_AI_MODEL_DEPLOYMENT_NAME="gpt-5.4"

# Optional care-record store (AAD/Managed Identity, no key). Leave unset to run as a stateless
# advisor; set to enable the fetch_recent_events / fetch_patient_state / log_care_briefing tools.
AIRACARE_COSMOS_ENDPOINT="https://<account>.documents.azure.com:443/"
AIRACARE_COSMOS_DATABASE="airacare"

# Cosmos authentication (in precedence order):
#   1. AIRACARE_COSMOS_KEY            — explicit account key (dev/manual override; leave unset).
#   2. Key Vault                      — set both of the following so the running identity (Managed
#      Identity in the container / az login locally) fetches the key from Key Vault. This is how the
#      deployed hosted agent gets its key with NO secret in its environment. Preferred for deploy.
#   3. AAD / Managed Identity direct  — used when neither above is set (works where the identity has
#      a Cosmos data-plane role; used for keyless local dev).
# AIRACARE_COSMOS_KEY="<cosmos-account-key>"
# AIRACARE_COSMOS_KEY_VAULT_URI="https://<vault>.vault.azure.net/"
# AIRACARE_COSMOS_KEY_SECRET="airacare-cosmos-primary-key"

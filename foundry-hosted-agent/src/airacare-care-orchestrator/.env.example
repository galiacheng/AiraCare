# Foundry project endpoint (https://<project>.services.ai.azure.com/api/projects/<name>).
# Populated automatically by `azd provision`; set manually only for standalone local runs.
FOUNDRY_PROJECT_ENDPOINT="..."

# The model deployment name created by provisioning (default: gpt-5.4).
AZURE_AI_MODEL_DEPLOYMENT_NAME="gpt-5.4"

# Optional care-record store (AAD/Managed Identity, no key). Leave unset to run as a stateless
# advisor; set to enable the fetch_recent_events / fetch_patient_state / log_care_briefing tools.
AIRACARE_COSMOS_ENDPOINT="https://<account>.documents.azure.com:443/"
AIRACARE_COSMOS_DATABASE="airacare"

# Optional Cosmos account key. Leave UNSET for AAD/Managed Identity (preferred, no key — works
# locally via az login and anywhere the running identity holds a Cosmos data-plane role). Set it
# only for the deployed Foundry hosted agent, whose ServiceIdentity is not accepted by Cosmos
# data-plane RBAC; the tools then authenticate with the key instead.
# AIRACARE_COSMOS_KEY="<cosmos-account-key>"
